# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/stms?schema=public"

# ─────────────────────────────────────────────
# NextAuth.js
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Ollama AI Engine
# ─────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:e4b"
OLLAMA_TIMEOUT_MS="60000"

# ─────────────────────────────────────────────
# Map Provider
# ─────────────────────────────────────────────
# Optional: Mapbox API token. If set, uses Mapbox GL JS (mapbox://styles/mapbox/dark-v11).
# If omitted, falls back to MapLibre GL JS with the free CartoCDN dark-matter style.
# Obtain a token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─────────────────────────────────────────────
# Simulation Engine
# ─────────────────────────────────────────────
# Base tick interval in milliseconds at 1× speed.
# At higher speed multipliers the interval is divided: interval = SIMULATION_TICK_BASE_MS / speed
# Valid values: any positive integer (default: 30000 = 30 seconds)
SIMULATION_TICK_BASE_MS=30000

# Hour of day (0–23) at which the simulated clock starts when the engine is initialised or reset.
# Valid values: 0–23 (default: 6 = 06:00)
SIMULATION_START_HOUR=6
